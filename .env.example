# ─────────────────────────────────────────────────────────────────────────────
# flexrz-auth — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────────────────────

# Full URL of this auth service
# Local dev:  http://localhost:3002
# Production: https://your-auth.vercel.app
NEXTAUTH_URL=http://localhost:3002

# Random secret for signing JWTs and session cookies
# Generate: openssl rand -hex 32
# Must match NEXTAUTH_SECRET in the backend and frontend
NEXTAUTH_SECRET=replace-with-a-strong-random-secret

# ── Google OAuth ──────────────────────────────────────────────────────────────

# Google OAuth 2.0 credentials — create at https://console.cloud.google.com
# Authorised redirect URI must include: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Connected Services ────────────────────────────────────────────────────────

# URL of the booking-backend Express server (used for user lookups after sign-in)
# Local dev:  http://localhost:3001
# Production: https://your-backend.onrender.com
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Base URL of the Next.js booking frontend (used for post-auth redirects)
# Local dev:  http://localhost:3000
NEXT_PUBLIC_APP_HOST=localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────

# HMAC secret for booking handoff tokens passed from auth → frontend
# Generate: openssl rand -hex 32 (can match BOOKING_HANDOFF_SECRET in the frontend)
BOOKING_HANDOFF_SECRET=replace-with-a-strong-random-secret

# ── Debugging (development only) ─────────────────────────────────────────────

# Set to "true" to enable verbose NextAuth debug logging
NEXTAUTH_DEBUG=false

# Set to "true" to log all sign-in events
AUTH_DEBUG_SIGNIN=false

# Set to "true" to log all redirect decisions
AUTH_DEBUG_REDIRECT=false

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
